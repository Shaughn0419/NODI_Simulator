{
  "include": [
    "__init__.py",
    "dashboard",
    "data_objects.py",
    "illumination.py",
    "interferometric_trace.py",
    "intrinsic_scattering.py",
    "materials.py",
    "mie_engine.py",
    "nodi_simulator",
    "paper_aligned_profiles.py",
    "parameter_sweep.py",
    "pulse_analysis.py",
    "reference_field.py",
    "scattering_trace.py",
    "structured_particles.py",
    "tests",
    "tools",
    "trajectory.py",
    "tsuyama_phase_filter.py",
    "utils.py"
  ],
  "exclude": [
    "**/._*",
    "**/__pycache__",
    ".codex_pdf_venv",
    ".omx",
    ".pdf_output",
    ".pytest_cache",
    ".pytest_vendor",
    ".venv",
    ".venv-tests",
    "archive",
    "reports",
    "results",
    "tmp"
  ],
  "ignore": [
    "archive",
    "reports",
    "results",
    "tmp"
  ],
  "pythonVersion": "3.13",
  "typeCheckingMode": "off",
  "extraPaths": [
    "."
  ],
  "reportMissingImports": false,
  "reportAttributeAccessIssue": false,
  "reportArgumentType": false,
  "reportCallIssue": false,
  "reportGeneralTypeIssues": false,
  "reportIndexIssue": false,
  "reportReturnType": false,
  "reportMissingTypeStubs": false,
  "reportUnknownMemberType": false,
  "reportUnknownVariableType": false,
  "reportUnknownArgumentType": false
}
